generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  nombre   String
  correo   String @unique
  password String

  rol    String
  modulo String

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  createdAt DateTime @default(now())

  // RELACIONES
  visitasAccionadas    Visita[]              @relation("AccionPor")
  ocurrencias          Ocurrencia[]
  historialOcurrencias HistorialOcurrencia[]
  reportesSismo        ReporteSismo[]
  contratasSeguridad ContrataProveedor[] @relation("AprobacionSeguridadContrata")
  contratasAmbiente ContrataProveedor[] @relation("AprobacionAmbienteContrata")
}

model UnidadNegocio {
  id     Int    @id @default(autoincrement())
  nombre String
  estado String

  zonales UnidadNegocioZonal[]
}

model UnidadNegocioZonal {
  id Int @id @default(autoincrement())

  unidadNegocioId Int
  zonalId         Int

  unidadNegocio UnidadNegocio @relation(fields: [unidadNegocioId], references: [id])

  zonal Zonal @relation(fields: [zonalId], references: [id])
}

model Zonal {
  id     Int    @id @default(autoincrement())
  nombre String

  sedes Sede[]

  unidades UnidadNegocioZonal[]
}

model Sede {
  id     Int    @id @default(autoincrement())
  nombre String

  zonalId Int
  zonal   Zonal @relation(fields: [zonalId], references: [id])
  registroRiesgos RegistroRiesgo[]
  usuarios User[]

  pabellones        Pabellon[]
  visitas           Visita[]
  ocurrencias       Ocurrencia[]
  reportesSismo     ReporteSismo[]
  contratas ContrataProveedor[]
  autorizacionSismo AutorizacionSismo?
}

model Pabellon {
  id     Int    @id @default(autoincrement())
  nombre String

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])
  registroRiesgos RegistroRiesgo[]
  pisos Piso[]
  contratas ContrataProveedor[]
}

model Piso {
  id     Int    @id @default(autoincrement())
  nombre String

  pabellonId Int
  pabellon   Pabellon @relation(fields: [pabellonId], references: [id])

  ambientes Ambiente[]
  registroRiesgos RegistroRiesgo[]
  contratas ContrataProveedor[]
}

model Ambiente {
  id     Int    @id @default(autoincrement())
  nombre String

  pisoId      Int
  piso        Piso         @relation(fields: [pisoId], references: [id])
  visitas     Visita[]
  ocurrencias Ocurrencia[]
  registroRiesgos RegistroRiesgo[]
  contratas ContrataProveedor[]
}

model Visita {
  id Int @id @default(autoincrement())

  codigo String @unique

  tipo   String
  motivo String

  // PENDIENTE | AUTORIZADO | DESAUTORIZADO | CANCELADO
  estado String

  fechaInicio DateTime @db.Date
  fechaFin    DateTime @db.Date

  horaEntrada String?
  horaSalida  String?
  accionPorId Int?

  accionPor User? @relation("AccionPor", fields: [accionPorId], references: [id])

  motivoAccion String?

  fechaAccion DateTime?
  sedeId Int

  sede Sede @relation(fields: [sedeId], references: [id])

  ambienteId Int

  ambiente Ambiente @relation(fields: [ambienteId], references: [id])

  visitantes Visitante[]

  contactoExterno ContactoExterno[]

  createdAt String
}

model Visitante {
  id Int @id @default(autoincrement())

  dni             String
  nombres         String
  apellidoPaterno String
  apellidoMaterno String

  email   String?
  empresa String?

  qrData   String?
  estadoQr String

  // DATOS INDIVIDUALES
  horaIngreso String?
  horaSalida  String?

  visitaId Int
  visita   Visita @relation(fields: [visitaId], references: [id])
}

model ContactoExterno {
  id Int @id @default(autoincrement())

  nombre  String
  email   String
  empresa String?

  visitaId Int

  visita Visita @relation(fields: [visitaId], references: [id])

  @@index([visitaId])
}

model Ocurrencia {
  id Int @id @default(autoincrement())

  codigo String @unique

  categoria    String
  tipo         String
  subcategoria String

  detalle String

  motivo  String?
  vinculo String?

  personaInvolucrada String?

  estado    String
  prioridad String?

  fecha DateTime @default(now())

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  ambienteId Int
  ambiente   Ambiente @relation(fields: [ambienteId], references: [id])

  // Nota: Asegúrate de tener definido el modelo EvidenciaOcurrencia en algún lado si vas a usarlo.
  // evidencias EvidenciaOcurrencia[] 

  historial  HistorialOcurrencia[]
  evidencias EvidenciaOcurrencia[]
  createdAt  DateTime              @default(now())
}

model HistorialOcurrencia {
  id Int @id @default(autoincrement())

  tipo String
  // REPORTE | SOLUCION | CIERRE | COMENTARIO

  mensaje String

  estadoAnterior String?
  estadoNuevo    String?

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])

  ocurrenciaId Int
  ocurrencia   Ocurrencia @relation(fields: [ocurrenciaId], references: [id])

  evidencias EvidenciaHistorial[]

  createdAt DateTime @default(now())
}

model EvidenciaHistorial {
  id Int @id @default(autoincrement())

  url String

  historialId Int
  historial   HistorialOcurrencia @relation(fields: [historialId], references: [id])

  createdAt DateTime @default(now())
}

model EvidenciaOcurrencia {
  id Int @id @default(autoincrement())

  url String

  ocurrenciaId Int
  ocurrencia   Ocurrencia @relation(fields: [ocurrenciaId], references: [id])

  createdAt DateTime @default(now())
}

model ReporteSismo {
  id Int @id @default(autoincrement())

  codigo String @unique

  fechaIncidente DateTime
  horaIncidente  String

  fechaReporte DateTime
  horaReporte  String

  responsableId Int
  responsable   User @relation(fields: [responsableId], references: [id])

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  operacion    Boolean
  corteEnergia Boolean

  evacuaron        Boolean
  tiempoEvacuacion String?

  danios            Boolean
  descripcionDanios String?

  victimas         Boolean
  cantidadVictimas Int?

  continuidad            Boolean
  descripcionContinuidad String?

  estado String @default("REPORTADO")

  createdAt DateTime @default(now())

  evidencias EvidenciaSismo[]
}

model EvidenciaSismo {
  id Int @id @default(autoincrement())

  url String

  reporteSismoId Int

  reporteSismo ReporteSismo @relation(fields: [reporteSismoId], references: [id])

  createdAt DateTime @default(now())
}

model AutorizacionSismo {
  id Int @id @default(autoincrement())

  sedeId Int  @unique
  sede   Sede @relation(fields: [sedeId], references: [id])

  plano String

  estado String @default("PENDIENTE")
  // PENDIENTE, APROBADO, RECHAZADO

  createdAt DateTime @default(now())
}
model ResponsableRiesgo {
  id Int @id @default(autoincrement())

  nombre          String
  apellidoPaterno String
  apellidoMaterno String

  correo String

  area      String
  categoria String

  estado String @default("ACTIVO")
  riesgos RegistroRiesgo[]
  createdAt DateTime @default(now())
}
model RegistroRiesgo {

  id Int @id @default(autoincrement())

  codigo String @unique

  sedeId Int
  sede Sede @relation(fields:[sedeId], references:[id])

  pabellonId Int
  pabellon Pabellon @relation(fields:[pabellonId], references:[id])

  pisoId Int
  piso Piso @relation(fields:[pisoId], references:[id])

  ambienteId Int
  ambiente Ambiente @relation(fields:[ambienteId], references:[id])

  categoria String

  riesgo String

  probabilidad Int

  impacto Int

  nivel Int

  descripcion String

  estado String @default("PENDIENTE")

  foto String?

  responsableId Int?

  responsable ResponsableRiesgo? @relation(fields: [responsableId], references: [id])

  createdAt DateTime @default(now())

  tratamientos TratamientoRiesgo[]

  seguimientos SeguimientoRiesgo[]
}

model TratamientoRiesgo {

  id Int @id @default(autoincrement())

  registroRiesgoId Int

  registroRiesgo RegistroRiesgo @relation(fields: [registroRiesgoId], references: [id])

  tipoTratamiento String

  planAccion String

  presupuesto String?

  estado String @default("EN PROCESO")

  createdAt DateTime @default(now())
}

model SeguimientoRiesgo {

  id Int @id @default(autoincrement())

  registroRiesgoId Int

  registroRiesgo RegistroRiesgo @relation(fields: [registroRiesgoId], references: [id])

  comentario String

  evidencia String?

  createdAt DateTime @default(now())
}
model ContrataProveedor {
  id Int @id @default(autoincrement())

  codigo String @unique

  // UBICACIÓN
  sedeId Int
  sede Sede @relation(fields:[sedeId], references:[id])

  pabellonId Int
  pabellon Pabellon @relation(fields:[pabellonId], references:[id])

  pisoId Int
  piso Piso @relation(fields:[pisoId], references:[id])

  ambienteId Int
  ambiente Ambiente @relation(fields:[ambienteId], references:[id])

  // DATOS DE LA CONTRATA
  motivo String
  empresaContratista String
  descripcionServicio String

  fechaInicio DateTime @db.Date
  fechaFin DateTime @db.Date

  horaEntrada String
  horaSalida String

  // RESPONSABLE
  emailResponsable String
  dniResponsable String
  nombresResponsable String
  apellidoPaternoResponsable String
  apellidoMaternoResponsable String
  telefonoResponsable String

  // ACCESO
  tokenAcceso String @unique
  nivelRiesgo String?

  // ESTADO DEL FLUJO
  estado String @default("PENDIENTE")

  // SEGURIDAD
  aprobadoSeguridadPorId Int?
  aprobadoSeguridadPor User? @relation("AprobacionSeguridadContrata",fields: [aprobadoSeguridadPorId],references: [id])
  fechaAprobacionSeguridad DateTime?

  // AMBIENTE
  aprobadoAmbientePorId Int?
  aprobadoAmbientePor User? @relation("AprobacionAmbienteContrata",fields: [aprobadoAmbientePorId],references: [id])
  fechaAprobacionAmbiente DateTime?

  // RECHAZO SEGURIDAD
  motivoRechazo String?

  createdAt DateTime @default(now())

  // RELACIONES
  trabajadores TrabajadorContrata[]
  documentos DocumentoContrata[]
}

model TrabajadorContrata {
  id Int @id @default(autoincrement())
  codigo String @unique
  dni String
  nombres String
  apellidoPaterno String
  apellidoMaterno String
  email String
  horaIngreso DateTime?
  horaSalida DateTime?
   qrData  String?
   estadoQr          String?
  contrataId Int
  contrata ContrataProveedor @relation(fields: [contrataId], references: [id])
  createdAt DateTime @default(now())
}
model DocumentoContrata {

  id Int @id @default(autoincrement())

  contrataId Int

  contrata ContrataProveedor @relation(fields: [contrataId], references: [id])

  tipo String

  archivo String

  createdAt DateTime @default(now())
}