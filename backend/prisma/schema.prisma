generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())

  nombre   String
  correo   String @unique
  password String

  rol    String
  modulo String

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  createdAt DateTime @default(now())

  // RELACIONES CRM (Kimberly)
  visitasAccionadas    Visita[]              @relation("AccionPor")
  ocurrencias          Ocurrencia[]
  historialOcurrencias HistorialOcurrencia[]
  reportesSismo        ReporteSismo[]

  // RELACIONES INVENTARIO (Carlos)
  proveedorId        Int?
  proveedor          Proveedor?          @relation(fields: [proveedorId], references: [id])
  servicios          HistorialServicio[]
  bajas              HistorialBaja[]
  contratasSeguridad ContrataProveedor[] @relation("AprobacionSeguridadContrata")
  contratasAmbiente  ContrataProveedor[] @relation("AprobacionAmbienteContrata")
  llaveros           Llavero[]
prestamosEntrega PrestamoLlavero[] @relation("ResponsableEntrega")
prestamosDevolucion PrestamoLlavero[]@relation("ResponsableDevolucion")
transferenciasResponsable  TransferenciaLlavero[]@relation("ResponsableTransferenciaLlavero")
}

model UnidadNegocio {
  id     Int    @id @default(autoincrement())
  nombre String
  estado String

  zonales UnidadNegocioZonal[]
}

model UnidadNegocioZonal {
  id Int @id @default(autoincrement())

  unidadNegocioId Int
  zonalId         Int

  unidadNegocio UnidadNegocio @relation(fields: [unidadNegocioId], references: [id])

  zonal Zonal @relation(fields: [zonalId], references: [id])
}

model Zonal {
  id     Int    @id @default(autoincrement())
  nombre String

  sedes Sede[]

  unidades UnidadNegocioZonal[]
}

model Sede {
  id     Int    @id @default(autoincrement())
  nombre String

  zonalId         Int
  zonal           Zonal            @relation(fields: [zonalId], references: [id])
  registroRiesgos RegistroRiesgo[]
  usuarios        User[]

  pabellones        Pabellon[]
  visitas           Visita[]
  ocurrencias       Ocurrencia[]
  reportesSismo     ReporteSismo[]
  contratas         ContrataProveedor[]
  autorizacionSismo AutorizacionSismo?
}

model Pabellon {
  id     Int    @id @default(autoincrement())
  nombre String

  sedeId          Int
  sede            Sede             @relation(fields: [sedeId], references: [id])
  registroRiesgos RegistroRiesgo[]
  pisos           Piso[]
}

model Piso {
  id     Int    @id @default(autoincrement())
  nombre String

  pabellonId Int
  pabellon   Pabellon @relation(fields: [pabellonId], references: [id])

  ambientes       Ambiente[]
  registroRiesgos RegistroRiesgo[]
}

model Ambiente {
  id     Int    @id @default(autoincrement())
  nombre String

  pisoId Int
  piso   Piso @relation(fields: [pisoId], references: [id])

  // RELACIONES
  visitas     Visita[]
  ocurrencias Ocurrencia[]

  // 🎯 NUEVO: Los activos de tu inventario ahora viven dentro de los ambientes del CRM
  activos         Activo[]
  registroRiesgos RegistroRiesgo[]
  contratas       ContrataProveedor[]
  llaves          Llave[]
}

model Activo {
  id            Int     @id @default(autoincrement())
  codigo        String  @unique
  nombre        String
  categoria     String
  sistema       String
  marca         String?
  modelo        String?
  serie         String?
  estado        String  @default("ACTIVO")
  estadoInv     String  @default("ALTA")
  observaciones String? @db.Text
  foto          String?

  // Relación con el Proveedor
  proveedorId Int?
  proveedor   Proveedor? @relation(fields: [proveedorId], references: [id])

  // Ubicación del Activo (conectado a la infraestructura del CRM)
  ambienteId Int
  ambiente   Ambiente @relation(fields: [ambienteId], references: [id])

  // Detalles adicionales
  extintor        DetalleExtintor?
  historial       HistorialServicio[]
  historicalBajas HistorialBaja[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modelos de soporte para Inventario
model Proveedor {
  id       Int      @id @default(autoincrement())
  nombre   String
  contacto String?
  usuarios User[]
  activos  Activo[]
}

model DetalleExtintor {
  id       Int    @id @default(autoincrement())
  activoId Int    @unique
  activo   Activo @relation(fields: [activoId], references: [id], onDelete: Cascade)

  capacidad   String?
  agente      String?
  numInterno  Int?
  fabricacion Int?

  fechaUltimaRecarga       DateTime?
  fechaUltimoMantenimiento DateTime?
  fechaUltimaPH            DateTime? // Prueba Hidrostática

  proximoServicioTipo  String? // "RECARGA", "MANTENIMIENTO" o "PH"
  proximoServicioFecha DateTime? // Fecha de la alerta
  vencimientoPH        DateTime? // Fecha exacta de su próxima PH (Cada 5 años)
}

model HistorialServicio {
  id          Int      @id @default(autoincrement())
  descripcion String
  fecha       DateTime @default(now())
  activoId    Int
  activo      Activo   @relation(fields: [activoId], references: [id])
  usuarioId   Int
  usuario     User     @relation(fields: [usuarioId], references: [id])
}

model HistorialBaja {
  id Int @id @default(autoincrement())

  activoId Int
  activo   Activo @relation(fields: [activoId], references: [id], onDelete: Cascade)

  motivoBaja        String // Cambiado de 'motivo' a 'motivoBaja' para el controlador
  observacionesBaja String? @db.Text
  fotoBaja          String?

  usuarioId Int?
  // 💡 Si en tu schema local el modelo de usuarios se llama 'User', déjalo como 'User'. 
  // Si se llama 'Usuario', cámbialo a 'Usuario'.
  usuario   User? @relation(fields: [usuarioId], references: [id])

  fechaBaja       DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  registroRiesgos RegistroRiesgo[]
}

model Visita {
  id Int @id @default(autoincrement())

  codigo String @unique

  tipo   String
  motivo String

  // PENDIENTE | AUTORIZADO | DESAUTORIZADO | CANCELADO
  estado String

  fechaInicio DateTime @db.Date
  fechaFin    DateTime @db.Date

  horaEntrada String?
  horaSalida  String?
  accionPorId Int?

  accionPor User? @relation("AccionPor", fields: [accionPorId], references: [id])

  motivoAccion String?

  fechaAccion DateTime?
  sedeId      Int

  sede Sede @relation(fields: [sedeId], references: [id])

  ambienteId Int

  ambiente Ambiente @relation(fields: [ambienteId], references: [id])

  visitantes Visitante[]

  contactoExterno ContactoExterno[]

  createdAt String
}

model Visitante {
  id Int @id @default(autoincrement())

  dni             String
  nombres         String
  apellidoPaterno String
  apellidoMaterno String

  email   String?
  empresa String?

  qrData   String?
  estadoQr String

  // DATOS INDIVIDUALES
  horaIngreso String?
  horaSalida  String?

  visitaId Int
  visita   Visita @relation(fields: [visitaId], references: [id])
}

model ContactoExterno {
  id Int @id @default(autoincrement())

  nombre  String
  email   String
  empresa String?

  visitaId Int

  visita Visita @relation(fields: [visitaId], references: [id])

  @@index([visitaId])
}

model Ocurrencia {
  id Int @id @default(autoincrement())

  codigo String @unique

  categoria    String
  tipo         String
  subcategoria String

  detalle String

  motivo  String?
  vinculo String?

  personaInvolucrada String?

  estado    String
  prioridad String?

  fecha DateTime @default(now())

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  ambienteId Int
  ambiente   Ambiente @relation(fields: [ambienteId], references: [id])

  // Nota: Asegúrate de tener definido el modelo EvidenciaOcurrencia en algún lado si vas a usarlo.
  // evidencias EvidenciaOcurrencia[] 

  historial  HistorialOcurrencia[]
  evidencias EvidenciaOcurrencia[]
  createdAt  DateTime              @default(now())
}

model HistorialOcurrencia {
  id Int @id @default(autoincrement())

  tipo String
  // REPORTE | SOLUCION | CIERRE | COMENTARIO

  mensaje String

  estadoAnterior String?
  estadoNuevo    String?

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])

  ocurrenciaId Int
  ocurrencia   Ocurrencia @relation(fields: [ocurrenciaId], references: [id])

  evidencias EvidenciaHistorial[]

  createdAt DateTime @default(now())
}

model EvidenciaHistorial {
  id Int @id @default(autoincrement())

  url String

  historialId Int
  historial   HistorialOcurrencia @relation(fields: [historialId], references: [id])

  createdAt DateTime @default(now())
}

model EvidenciaOcurrencia {
  id Int @id @default(autoincrement())

  url String

  ocurrenciaId Int
  ocurrencia   Ocurrencia @relation(fields: [ocurrenciaId], references: [id])

  createdAt DateTime @default(now())
}

model ReporteSismo {
  id Int @id @default(autoincrement())

  codigo String @unique

  fechaIncidente DateTime
  horaIncidente  String

  fechaReporte DateTime
  horaReporte  String

  responsableId Int
  responsable   User @relation(fields: [responsableId], references: [id])

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  operacion    Boolean
  corteEnergia Boolean

  evacuaron        Boolean
  tiempoEvacuacion String?

  danios            Boolean
  descripcionDanios String?

  victimas         Boolean
  cantidadVictimas Int?

  continuidad            Boolean
  descripcionContinuidad String?

  estado String @default("REPORTADO")

  createdAt DateTime @default(now())

  evidencias EvidenciaSismo[]
}

model EvidenciaSismo {
  id Int @id @default(autoincrement())

  url String

  reporteSismoId Int

  reporteSismo ReporteSismo @relation(fields: [reporteSismoId], references: [id])

  createdAt DateTime @default(now())
}

model AutorizacionSismo {
  id Int @id @default(autoincrement())

  sedeId Int  @unique
  sede   Sede @relation(fields: [sedeId], references: [id])

  plano String

  estado String @default("PENDIENTE")
  // PENDIENTE, APROBADO, RECHAZADO

  createdAt DateTime @default(now())
}

model ResponsableRiesgo {
  id Int @id @default(autoincrement())

  nombre          String
  apellidoPaterno String
  apellidoMaterno String

  correo String

  area      String
  categoria String

  estado    String           @default("ACTIVO")
  riesgos   RegistroRiesgo[]
  createdAt DateTime         @default(now())
}

model RegistroRiesgo {
  id Int @id @default(autoincrement())

  codigo String @unique

  sedeId Int
  sede   Sede @relation(fields: [sedeId], references: [id])

  pabellonId Int
  pabellon   Pabellon @relation(fields: [pabellonId], references: [id])

  pisoId Int
  piso   Piso @relation(fields: [pisoId], references: [id])

  ambienteId Int
  ambiente   Ambiente @relation(fields: [ambienteId], references: [id])

  categoria String

  riesgo String

  probabilidad Int

  impacto Int

  nivel Int

  descripcion String

  estado String @default("PENDIENTE")

  foto            String?
  historialBajaId Int?
  historialBaja   HistorialBaja? @relation(fields: [historialBajaId], references: [id])

  responsableId Int?

  responsable ResponsableRiesgo? @relation(fields: [responsableId], references: [id])

  createdAt DateTime @default(now())

  tratamientos TratamientoRiesgo[]

  seguimientos SeguimientoRiesgo[]
}

model TratamientoRiesgo {
  id Int @id @default(autoincrement())

  registroRiesgoId Int

  registroRiesgo RegistroRiesgo @relation(fields: [registroRiesgoId], references: [id])

  tipoTratamiento String

  planAccion String

  presupuesto String?

  estado String @default("EN PROCESO")

  createdAt DateTime @default(now())
}

model SeguimientoRiesgo {
  id Int @id @default(autoincrement())

  registroRiesgoId Int

  registroRiesgo RegistroRiesgo @relation(fields: [registroRiesgoId], references: [id])

  comentario String

  evidencia String?

  createdAt DateTime @default(now())
}

model ContrataProveedor {
  id Int @id @default(autoincrement())

  codigo String @unique

  // UBICACIÓN
  sedeId     Int
  sede       Sede     @relation(fields: [sedeId], references: [id])
  ambienteId Int
  ambiente   Ambiente @relation(fields: [ambienteId], references: [id])

  // DATOS DE LA CONTRATA
  motivo              String
  empresaContratista  String
  descripcionServicio String

  fechaInicio DateTime @db.Date
  fechaFin    DateTime @db.Date

  horaEntrada String
  horaSalida  String

  // RESPONSABLE
  emailResponsable           String
  dniResponsable             String
  nombresResponsable         String
  apellidoPaternoResponsable String
  apellidoMaternoResponsable String
  telefonoResponsable        String

  // ACCESO
  tokenAcceso String  @unique
  nivelRiesgo String?

  // ESTADO DEL FLUJO
  estado String @default("PENDIENTE")

  // SEGURIDAD
  aprobadoSeguridadPorId   Int?
  aprobadoSeguridadPor     User?     @relation("AprobacionSeguridadContrata", fields: [aprobadoSeguridadPorId], references: [id])
  fechaAprobacionSeguridad DateTime?

  // AMBIENTE
  aprobadoAmbientePorId   Int?
  aprobadoAmbientePor     User?     @relation("AprobacionAmbienteContrata", fields: [aprobadoAmbientePorId], references: [id])
  fechaAprobacionAmbiente DateTime?

  // RECHAZO SEGURIDAD
  motivoRechazo String?

  createdAt DateTime @default(now())

  // RELACIONES
  trabajadores TrabajadorContrata[]
  documentos   DocumentoContrata[]
  prestamos PrestamoLlavero[]

transferenciasOrigen TransferenciaLlavero[] @relation("TransferenciaOrigen")

transferenciasDestino TransferenciaLlavero[] @relation("TransferenciaDestino")
}

model TrabajadorContrata {
  id              Int               @id @default(autoincrement())
  codigo          String            @unique
  dni             String
  nombres         String
  apellidoPaterno String
  apellidoMaterno String
  email           String
  horaIngreso     String?
  horaSalida      String?
  qrData          String?
  estadoQr        String?
  contrataId      Int
  contrata        ContrataProveedor @relation(fields: [contrataId], references: [id])
  createdAt       DateTime          @default(now())
}

model DocumentoContrata {
  id Int @id @default(autoincrement())

  contrataId Int

  contrata ContrataProveedor @relation(fields: [contrataId], references: [id])

  tipo String

  archivo String

  createdAt DateTime @default(now())
}

model Llavero {
  id Int @id @default(autoincrement())

  codigo String @unique

  nombre String

  descripcion String?

  tipoAgrupacion String

  estado String @default("DISPONIBLE")

  createdById Int

  createdBy User @relation(fields: [createdById], references: [id])

  createdAt      DateTime @default(now())
  llaves         Llave[]

  prestamos PrestamoLlavero[]
}

model Llave {
  id Int @id @default(autoincrement())

  codigo String @unique

  descripcion String?

  ambienteId Int
  ambiente   Ambiente @relation(fields: [ambienteId], references: [id])

  llaveroId Int
  llavero   Llavero @relation(fields: [llaveroId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model PrestamoLlavero {

  id Int @id @default(autoincrement())

  llaveroId Int
  llavero Llavero @relation(fields: [llaveroId], references: [id])

  contrataId Int?
  contrata ContrataProveedor? @relation(fields: [contrataId], references: [id])

  tipoMovimiento String

  responsableEntregaId Int?
  responsableEntrega User? @relation("ResponsableEntrega", fields: [responsableEntregaId], references: [id])

  responsableDevolucionId Int?
  responsableDevolucion User? @relation("ResponsableDevolucion", fields: [responsableDevolucionId], references: [id])

  fechaEntrega DateTime @default(now())

  fechaDevolucion DateTime?

  estado String

  detalle String?

  fotoEntrega String?

  fotoDevolucion String?

  createdAt DateTime @default(now())

  transferencias TransferenciaLlavero[]
}
model TransferenciaLlavero {

  id Int @id @default(autoincrement())

  prestamoId Int
  prestamo PrestamoLlavero @relation(fields: [prestamoId], references: [id])

  contrataOrigenId Int
  contrataOrigen ContrataProveedor @relation(name: "TransferenciaOrigen",fields: [contrataOrigenId],references: [id])

  contrataDestinoId Int
  contrataDestino ContrataProveedor @relation(name: "TransferenciaDestino",fields: [contrataDestinoId],references: [id] )

  responsableId Int?

  responsable User? @relation(name: "ResponsableTransferenciaLlavero",fields: [responsableId],references: [id])

  fecha DateTime @default(now())

  detalle String?
}